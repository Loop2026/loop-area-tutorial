# --- Supabase (progetto loop-area-tutorial, region eu-central-1) ---
# Valori reali del progetto wcqctjxtipgufgidztec già applicati:
NEXT_PUBLIC_SUPABASE_URL=https://wcqctjxtipgufgidztec.supabase.co

# Chiave pubblica "publishable" (raccomandata, rotabile indipendentemente):
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_yLZrx4Z2_fj4reJFKKtcJA_SNrqzTkZ

# Alternativa legacy JWT anon (compat con vecchie librerie):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndjcWN0anh0aXBndWZnaWR6dGVjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY1OTY2MjksImV4cCI6MjA5MjE3MjYyOX0.qVcHTcO-TTW8IPdf4QWbe4sTk5oRkap8_c5P2BpaPFw

# ⚠ Da recuperare manualmente da Supabase Dashboard → Settings → API → "service_role"
# MAI committare, MAI esporre al client. Usata SOLO in route /api/admin/* server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...SOSTITUISCI...

# --- Bunny.net Stream (video hosting) ---
# Da creare: bunny.net → Stream → + Add Video Library "loop-area-tutorial" (Europe only)
NEXT_PUBLIC_BUNNY_LIBRARY_ID=123456
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
BUNNY_STREAM_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Il LIBRARY_ID e CDN hostname sono pubblici (vengono nel player iframe).
# L'API_KEY è server-side only: serve solo se vuoi automatizzare upload via CLI.

# --- Branding (aggiorna dopo primo deploy Vercel) ---
NEXT_PUBLIC_SITE_URL=https://area-tutorial.loop.example.com
